#!/bin/bash
set -e

INSTALL_DIR="/opt/elden-ring-tracker"

if [ "$1" = "remove" ]; then
    pkill -f "streamlit run.*dashboard.py" 2>/dev/null || true
    pkill -f "python3.*tray.py" 2>/dev/null || true

    REAL_USER="${SUDO_USER:-${LOGNAME:-$(logname 2>/dev/null || true)}}"
    if [ -n "$REAL_USER" ]; then
        REAL_HOME=$(eval echo "~$REAL_USER")
        rm -f "$REAL_HOME/.config/autostart/elden-ring-tracker.desktop" 2>/dev/null || true
    else
        for f in /home/*/.config/autostart/elden-ring-tracker.desktop; do
            rm -f "$f" 2>/dev/null || true
        done
    fi
fi
