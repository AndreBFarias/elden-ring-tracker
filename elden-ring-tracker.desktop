[Desktop Entry]
Type=Application
Name=Elden Ring Tracker
Comment=Dashboard interativo para rastrear progresso em Elden Ring
Exec=bash -c "cd /opt/elden-ring-tracker && .venv/bin/python3 src/tray.py"
Icon=/opt/elden-ring-tracker/assets/icons/icon.png
Terminal=false
Categories=Game;Utility;
Keywords=elden;ring;tracker;souls;
StartupNotify=false
